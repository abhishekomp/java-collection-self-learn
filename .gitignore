# ─── macOS ────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ─── IntelliJ IDEA ────────────────────────────────────────────────────────────
# The .idea/ folder holds workspace-specific settings that differ between
# developers (paths, run configs, etc.) and should not be shared via git.
# Exception: .idea/modules.xml and .idea/*.xml checked in by some teams —
# for a learning project it is simpler to ignore the whole directory.
.idea/
*.iml
*.iws
out/

# ─── Maven ────────────────────────────────────────────────────────────────────
# 'target/' is the Maven build output directory (compiled classes, JARs, reports).
# It is always regenerated by 'mvn compile' / 'mvn test', so it must not be committed.
target/

# ─── Java ─────────────────────────────────────────────────────────────────────
# Compiled class files and packaging artifacts produced during builds.
*.class
*.jar
*.war
*.ear
*.nar

# ─── Log files ────────────────────────────────────────────────────────────────
# All .log files in this project are intentionally tracked — they serve as
# reference data, req-res captures, and sample inputs for learning exercises.
# (No ignore rule for *.log)

# ─── Shell scripts in project root ────────────────────────────────────────────
# Scripts like extract_tenant.bash are local helper scripts, not part of the
# learning source.  Remove this line if you want to track them.
*.bash
*.sh

# ─── Scratch / notes files ────────────────────────────────────────────────────
# Plain-text scratch files (output.txt, etc.) generated during manual runs.
output.txt

# ─── SDKMAN ───────────────────────────────────────────────────────────────────
# .sdkmanrc pins the Java version for this project.
# We intentionally KEEP this tracked so anyone cloning the repo can run
# 'sdk env install' to get exactly JDK 21.
# (No entry here means it WILL be committed — which is what we want.)
